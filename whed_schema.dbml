  cRecordHistory "longtext" [not null]
  UserID "mediumint(8) unsigned"
  cWarning "tinyint(3) unsigned" [not null, default: 0]
  cDelete "tinyint(3) unsigned" [not null, default: 0]

  Indexes {
    CredID [unique, name: "CredGUID"]
    CredLevelCode [name: "CredLevelCode"]
    StateID [name: "StateID"]
    UserID [name: "UserID"]
  }
}


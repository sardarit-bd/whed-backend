Table whed_action {
  ActionID "int(10) unsigned" [pk, increment]
  UserID "int(10) unsigned" [not null, default: 0]
  created "int(11)" [not null, default: 0]
  mail "varchar(64)" [not null, default: '']
  controle "varchar(32)" [not null, default: '']
  action "varchar(32)" [not null, default: '']
  requete "text" [not null]
  success "tinyint(4)" [not null, default: 0]
  token_hash "varchar(255)" [not null]
  expires_at "datetime" [not null]
  created_at "datetime" [default: `current_timestamp()`]
}

Table whed_articles {
  ArticleID "varchar(30)" [pk, not null, default: '']
  Statique "tinyint(3) unsigned" [not null, default: 0]
  Status "tinyint(3) unsigned" [not null, default: 0]
  Vignette "varchar(30)" [not null, default: '']
  Titre "varchar(100)"
  Site "varchar(255)" [not null, default: '']
  Texte "text"
  DateCreate "int(11)" [not null, default: 0]
  DateUpdate "int(11)" [not null, default: 0]

  Indexes {
    ArticleID [name: "ArticleID"]
  }
}

Table whed_contact {
  ContactID "mediumint(8) unsigned" [pk, increment]
  OrgID "mediumint(8) unsigned"
  Surname "varchar(60)"
  FirstName "varchar(60)"
  JobTitle "varchar(100)"
  JobFunctionCode "varchar(2)"
  YearsOfOffice "varchar(45)"
  ContactTel "varchar(60)"
  ContactEMail "varchar(100)"
  Sex "varchar(1)"

  Indexes {
    ContactID [name: "ContactID"]
    FirstName [name: "FirstName"]
    JobFunctionCode [name: "JobFunctionCode"]
    JobTitle [name: "JobTitle"]
    OrgID [name: "OrgID"]
    Surname [name: "Surname"]
  }
}

Table whed_cred {
